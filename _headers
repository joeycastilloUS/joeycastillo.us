# metal Latchkey Doors -- artifacts are republished in place (widget upgrades,
# re-renders) and shared by link; never serve a stale copy or the comment
# thread breaks silently against an old backend contract.
/metal/s/*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

# Don't let the browser cache the gate or the gated landing pages -- the
# password gate is a simple SHA-256 client-side check; if we update the
# script (e.g. to fix iframe race conditions) we want the new version
# served immediately, not on whatever stale-while-revalidate window the
# CDN happens to pick.

/airbyte-migration/gate.js
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/airbyte-migration/parity
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/airbyte-migration/parity.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/airbyte-migration/index.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/audit/gate.js
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/audit/gate.css
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/audit/index.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/audit/
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

# Mendo Konductor customer deliverables (session reports + AARs, incl. PDFs).
# These get updated in place and emailed as links -- never serve a stale copy.
/mendo-konductor/session/*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/mendo-konductor/aar/*
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

# Argus (NOC for Meraki) -- the app ships frequently; never serve a stale copy
# so changes show the moment they deploy (no hard-refresh required).
/argus/mendo/
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/argus/mendo/index.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/argus/mendo/checks-content.json
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

# Don't let the browser cache the gate or the gated landing pages -- the
# password gate is a simple SHA-256 client-side check; if we update the
# script (e.g. to fix iframe race conditions) we want the new version
# served immediately, not on whatever stale-while-revalidate window the
# CDN happens to pick.

/airbyte-migration/gate.js
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/airbyte-migration/parity
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/airbyte-migration/parity.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/airbyte-migration/index.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
